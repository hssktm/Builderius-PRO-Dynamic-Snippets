# name: YouTube Playlist API
# desc: Fetches videos from a YouTube playlist using the Google API. Important: This snippet uses API tokens and repeated requests can be costly.

{
  raw_response: php_function_output(
    function: "wp_remote_get",
    arguments: ["https://www.googleapis.com/youtube/v3/playlistItems?part=snippet&playlistId=[YOUR_PLAYLIST_ID]&maxResults=10&key=[YOUR_API_KEY]"]
  ) @private

  response_body: php_function_output(
    function: "wp_remote_retrieve_body",
    arguments: ["{{raw_response}}"]
  ) @private

  decoded_data: php_function_output(
    function: "json_decode",
    arguments: ["{{response_body}}", true]
  ) @private

  youtube_list: expression_result(
    expression: "foreach(decoded_data.items, (item) -> { { id: item.snippet.resourceId.videoId, title: item.snippet.title, image: item.snippet.thumbnails.high.url } })"
  )
}
